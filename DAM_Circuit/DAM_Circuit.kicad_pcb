		)
	)
	(gr_text "LCD INDICATOR AND EVENTS:\n\n00 LEVEL - DRAINING CALIBRATION\n01 LEVEL - NO EVENT\n02 LEVEL - NO EVENT\n03 LEVEL - NO EVENT\n04 LEVEL - GREATER THAN 4 OPENS GATE 1\n05 LEVEL - NO EVENT\n06 LEVEL - NOTHING\n07 LEVEL - NOTHING\n08 LEVEL - GREATER THAN 8 OPENS GATE 2\n09 LEVEL - NO EVENT\n10 LEVEL - ALARM ACTIVATED"
		(at 229.5 163.5 0)
		(layer "B.SilkS" knockout)
		(uuid "b16d05f2-b044-46fb-80c6-d3197780ab27")
		(effects
			(font
				(size 1 1)
				(thickness 0.1)
			)
			(justify left bottom mirror)
		)
	)
	(gr_text "The PCB serves as the central hardware controller for an automated dam spillway system, processing inputs \nfrom 10 Hall Effect sensors through a priority encoder and combinational logic to manage two solenoid valves.\nAdditionally, the board drivesa 7-segment display forreal-time water level monitoring and triggers a continuous\nemergency alarm at critical thresholds, providing a complete discrete digital logic solution."
		(at 157.5 116 0)
		(layer "B.SilkS" knockout)
		(uuid "d7221426-1d4f-4702-b79c-0b2ed91c1eb6")
		(effects
			(font
				(size 1.2 1.2)
				(thickness 0.1)
			)
			(justify mirror)
		)
	)
	(gr_text "这块PCB作为自动化大坝溢洪系统的中央硬件控制器，通过优先编码器和组合逻辑处理来自10\n个霍尔效应传感器的输入，以控制两个电磁阀。此外，该电路板驱动7段数码管进行实时水位监测，\n并在达到临界水位时触发持续的紧急警报，提供了一个完整的分立数字逻辑解决方案。"
		(at 147.5 150.5 0)
		(layer "B.SilkS" knockout)
		(uuid "5ee17400-6162-4a09-bca0-35acbfdb1c41")
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1)
			)
			(justify mirror)
		)
	)
